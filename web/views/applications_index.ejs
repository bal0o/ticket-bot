<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Applications</title>
  <link rel="stylesheet" href="/static/styles.css">
</head>
<body>
  <header class="navbar">
    <div class="nav-left"><a href="/my">BritRust Ticket System</a></div>
    <div class="nav-right">
      <a class="btn" href="/my">My Tickets</a>
      <% if (canSeeApplications) { %>
      <a class="btn" href="/applications">Applications</a>
      <% } %>
      <% if (roleFlags && roleFlags.isStaff) { %>
        <a class="btn" href="/staff">Staff View</a>
      <% } %>
      <a class="btn" href="/logout">Logout</a>
    </div>
  </header>
  <main class="container">
    <h1>Applications</h1>
    <div style="margin-bottom:12px; display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
      <span class="muted">View:</span>
      <a class="btn <%= !kind || kind === 'all' ? 'active' : '' %>" href="/applications?<% if (request && request.query && request.query.all) { %>all=1&<% } %>">All (<%= (devCount || 0) + (staffCount || 0) %>)</a>
      <a class="btn <%= kind === 'staff' ? 'active' : '' %>" href="/applications?kind=staff<% if (request && request.query && request.query.all) { %>&all=1<% } %>">Staff (<%= staffCount || 0 %>)</a>
      <a class="btn <%= kind === 'dev' ? 'active' : '' %>" href="/applications?kind=dev<% if (request && request.query && request.query.all) { %>&all=1<% } %>">Dev (<%= devCount || 0 %>)</a>
    </div>
    <form method="get" action="/applications" class="filters" style="margin-bottom:16px; display:flex; gap:12px; flex-wrap:wrap; align-items:end;">
      <label>Stage:
        <input type="text" name="stage" value="<%= stage || '' %>">
      </label>
      <% if (pagination) { %>
      <label>Page size:
        <select name="limit">
          <option value="10" <%= String(pagination.limit) === '10' ? 'selected' : '' %>>10</option>
          <option value="25" <%= String(pagination.limit) === '25' ? 'selected' : '' %>>25</option>
          <option value="50" <%= String(pagination.limit) === '50' ? 'selected' : '' %>>50</option>
          <option value="100" <%= String(pagination.limit) === '100' ? 'selected' : '' %>>100</option>
        </select>
      </label>
      <input type="hidden" name="page" value="1">
      <% } %>
      <button type="submit" class="btn primary">Filter</button>
      <% if (!request || !request.query || !request.query.all) { %>
        <a class="btn" href="/applications?all=1">Show All (incl. Approved/Denied/Archived)</a>
      <% } else { %>
        <a class="btn" href="/applications">Show Active Only</a>
      <% } %>
    </form>
    <form method="post" action="/applications/batch">
      <div class="table-scroll">
      <table class="with-filter">
        <thead>
          <tr>
            <th><input type="checkbox" id="select-all"></th>
            <th>Applicant</th>
            <th>Type</th>
            <th>Server</th>
            <th>Stage</th>
            <th>Updated</th>
            <th>Open</th>
          </tr>
        </thead>
        <tbody>
          <% (items || []).forEach(a => { %>
            <% const displayName = (applicantNames && applicantNames[String(a.userId)]) || a.username || a.userId; %>
            <tr>
              <td><input type="checkbox" name="ids" value="<%= a.id %>"></td>
              <td>
                <div style="display:flex; flex-direction:column;">
                  <span><%= displayName %></span>
                  <span class="muted" style="font-size:11px;">Discord: <%= a.userId %></span>
                </div>
              </td>
              <td><%= a.type %></td>
              <td><%= a.server || '' %></td>
              <td><%= a.stage %></td>
              <td><%= a.updatedAt ? new Date(a.updatedAt).toLocaleString() : '' %></td>
              <td><a class="btn" href="/applications/<%= a.id %>">View</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      </div>
      <div style="margin-top:12px; display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
        <label>Batch action:
          <select name="action" required>
            <option value="">Select…</option>
            <option value="advance">Advance to next stage</option>
            <option value="deny">Deny</option>
            <option value="archive">Archive</option>
          </select>
        </label>
        <input type="text" name="note" placeholder="Optional note / reason" style="flex:1; min-width:220px;">
        <button type="submit" class="btn primary">Apply to selected</button>
      </div>
    </form>
    <% if (pagination && pagination.totalPages > 1) { %>
      <nav class="pagination">
        <% const prev = Math.max(1, (pagination.page || 1) - 1); %>
        <% const next = Math.min(pagination.totalPages, (pagination.page || 1) + 1); %>
        <a class="btn" href="?page=<%= prev %>&limit=<%= pagination.limit %><% if (stage) { %>&stage=<%= encodeURIComponent(stage) %><% } %><% if (request && request.query && request.query.all) { %>&all=1<% } %>">Prev</a>
        <% const p = pagination.page || 1; const tp = pagination.totalPages || 1; const start = Math.max(1, p - 2); const end = Math.min(tp, p + 2); %>
        <% if (start > 1) { %>
          <a class="btn" href="?page=1&limit=<%= pagination.limit %><% if (stage) { %>&stage=<%= encodeURIComponent(stage) %><% } %><% if (request && request.query && request.query.all) { %>&all=1<% } %>">1</a>
          <% if (start > 2) { %><span class="muted">…</span><% } %>
        <% } %>
        <% for (let i = start; i <= end; i++) { %>
          <% if (i === p) { %>
            <span class="btn active"><%= i %></span>
          <% } else { %>
            <a class="btn" href="?page=<%= i %>&limit=<%= pagination.limit %><% if (stage) { %>&stage=<%= encodeURIComponent(stage) %><% } %><% if (request && request.query && request.query.all) { %>&all=1<% } %>"><%= i %></a>
          <% } %>
        <% } %>
        <% if (end < tp) { %>
          <% if (end < tp - 1) { %><span class="muted">…</span><% } %>
          <a class="btn" href="?page=<%= tp %>&limit=<%= pagination.limit %><% if (stage) { %>&stage=<%= encodeURIComponent(stage) %><% } %><% if (request && request.query && request.query.all) { %>&all=1<% } %>"><%= tp %></a>
        <% } %>
        <a class="btn" href="?page=<%= next %>&limit=<%= pagination.limit %><% if (stage) { %>&stage=<%= encodeURIComponent(stage) %><% } %><% if (request && request.query && request.query.all) { %>&all=1<% } %>">Next</a>
      </nav>
    <% } %>
  </main>
  <script>
    (function () {
      const selectAll = document.getElementById('select-all');
      if (!selectAll) return;
      selectAll.addEventListener('change', function () {
        const boxes = document.querySelectorAll('input[type="checkbox"][name="ids"]');
        boxes.forEach(cb => { cb.checked = selectAll.checked; });
      });
    })();
  </script>
</body>
</html>


