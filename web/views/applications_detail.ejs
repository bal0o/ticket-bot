<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Application</title>
  <link rel="stylesheet" href="/static/styles.css">
</head>
<body>
  <header class="navbar">
    <div class="nav-left"><a href="/applications">Applications</a></div>
    <div class="nav-right"><a class="btn" href="/logout">Logout</a></div>
  </header>
  <main class="container">
    <h1>Application: <%= app.username %> (<%= app.userId %>)</h1>
    <p class="muted">Stage: <strong><%= app.stage %></strong> • Type: <%= app.type %> • Server: <%= app.server || '' %></p>
    <div class="grid two">
      <section>
        <h3>Stages</h3>
        <div class="stages">
          <% (stages || ['Submitted','Initial Review','Background Check','Interview','Final Decision','Archived']).forEach(function(s){ const active = s === app.stage; %>
            <span class="stage <%= active ? 'active' : '' %>"><%= s %></span>
          <% }); %>
        </div>
      </section>
      <section>
        <h3>Responses</h3>
        <pre class="pre" style="max-height:420px; overflow:auto;"><%= app.responses || 'No responses recorded' %></pre>
        <h3>Tickets</h3>
        <ul>
          <% (app.tickets || []).forEach(t => { %>
            <li>#<%= t.ticketId %> — <span class="muted"><%= new Date(t.createdAt).toLocaleString() %></span></li>
          <% }) %>
          <% if ((app.tickets||[]).length===0) { %><li class="muted">None yet</li><% } %>
        </ul>
      </section>
      <section>
        <h3>History</h3>
        <ul>
          <% (app.history || []).forEach(h => { %>
            <li><strong><%= h.stage %></strong> <span class="muted"><%= new Date(h.at).toLocaleString() %></span> <%= h.by ? `by ${userNames[String(h.by)] || h.by}` : '' %><br><span class="muted"><%= h.note || '' %></span></li>
          <% }) %>
        </ul>
        <h3>Comments</h3>
        <ul>
          <% (app.comments || []).forEach(c => { %>
            <li><strong><%= userNames[String(c.by)] || c.by %></strong> <span class="muted"><%= new Date(c.at).toLocaleString() %></span><br><div class="pre"><%= c.comment %></div></li>
          <% }) %>
        </ul>
        <form method="post" action="/applications/<%= app.id %>/comment" style="margin:12px 0;">
          <textarea name="comment" rows="3" style="width:100%" placeholder="Add comment..."></textarea>
          <button class="btn primary" type="submit" <%= (app.stage === 'Denied' || app.stage === 'Archived') ? 'disabled' : '' %>>Add Comment</button>
        </form>
        <% if (canAdmin && app.stage !== 'Denied' && app.stage !== 'Archived') { %>
          <h3>Actions</h3>
          <form method="post" action="/applications/<%= app.id %>/advance" style="display:flex; gap:8px; align-items:center;">
            <span class="muted">Next Stage:</span>
            <strong><%= nextStage %></strong>
            <input type="text" name="note" placeholder="Note" style="flex:1;">
            <button class="btn primary" type="submit">Advance</button>
          </form>
          <form method="post" action="/applications/<%= app.id %>/deny" style="margin-top:8px; display:flex; gap:8px; align-items:center;">
            <input type="text" name="note" placeholder="Reason">
            <button class="btn" type="submit">Deny</button>
          </form>
          <h3>Contact / Interview</h3>
          <form method="post" action="/applications/<%= app.id %>/open_ticket" style="display:flex; gap:8px; align-items:center;">
            <button class="btn" type="submit">Open Communication Ticket</button>
          </form>
          <% if (app.stage === 'Interview') { %>
            <form method="post" action="/applications/<%= app.id %>/schedule" style="margin-top:8px; display:flex; gap:8px; align-items:center;">
              <label>Interview time: <input type="datetime-local" name="when"></label>
              <label>Staff ID: <input type="text" name="staff_id" placeholder="Discord Staff ID"></label>
              <button class="btn" type="submit">Schedule Interview</button>
            </form>
          <% } %>
        <% } %>
      </section>
    </div>
    <% if (canAdmin && app.stage !== 'Denied' && app.stage !== 'Archived') { %>
      <h3>Actions</h3>
      <form method="post" action="/applications/<%= app.id %>/advance" style="display:flex; gap:8px; align-items:center;">
        <span class="muted">Next Stage:</span>
        <strong><%= nextStage %></strong>
        <input type="text" name="note" placeholder="Note" style="flex:1;">
        <button class="btn primary" type="submit">Advance</button>
      </form>
      <form method="post" action="/applications/<%= app.id %>/deny" style="margin-top:8px; display:flex; gap:8px; align-items:center;">
        <input type="text" name="note" placeholder="Reason">
        <button class="btn" type="submit">Deny</button>
      </form>
      <h3>Contact / Interview</h3>
      <form method="post" action="/applications/<%= app.id %>/open_ticket" style="display:flex; gap:8px; align-items:center;">
        <button class="btn" type="submit">Open Communication Ticket</button>
      </form>
      <form method="post" action="/applications/<%= app.id %>/schedule" style="margin-top:8px; display:flex; gap:8px; align-items:center;">
        <label>Interview time: <input type="datetime-local" name="when"></label>
        <label>Staff ID: <input type="text" name="staff_id" placeholder="Discord Staff ID"></label>
        <button class="btn" type="submit">Schedule Interview</button>
      </form>
    <% } %>
  </main>
</body>
</html>


